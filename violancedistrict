-- ==========================================
-- TAB: UTILITIES
-- ==========================================
local UtilsTab = Window:AddTab("Utilities", "settings")

UtilsTab:AddToggle({
    Title = "Noclip (Tembus Tembok)",
    Desc = "Bisa tembus semua objek/tembok di map",
    Callback = function(state)
        _G.Noclip = state
        game:GetService("RunService").Stepped:Connect(function()
            if _G.Noclip and game.Players.LocalPlayer.Character then
                for _, v in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end
        end)
    end
})

UtilsTab:AddToggle({
    Title = "Anti-Staff Detection",
    Callback = function(state)
        _G.AntiStaff = state
        spawn(function()
            while _G.AntiStaff do
                for _, p in pairs(game.Players:GetPlayers()) do
                    if p:GetRankInGroup(0) > 100 then -- Sesuaikan ID Group
                        game.Players.LocalPlayer:Kick("Staff Detected!")
                    end
                end
                task.wait(2)
            end
        end)
    end
})

UtilsTab:AddSlider({
    Title = "WalkSpeed",
    Min = 16, Max = 300, Default = 16,
    Callback = function(v)
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = v
    end
})

UtilsTab:AddToggle({
    Title = "ESP Players",
    Callback = function(state) end
})

