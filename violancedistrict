KillTab:AddToggle({ Title = "Instant Kill ALL", Callback = function(s) end })
KillTab:AddButton({ Title = "Teleport to Survivor", Callback = function() end })

-- ==========================================
-- TAB: PERFORMANCE
-- ==========================================
local PerfTab = Window:AddTab("Performance", "zap")

PerfTab:AddButton({
    Title = "FPS Booster + Clear Textures",
    Callback = function()
        game:GetService("Lighting").GlobalShadows = false
        for _, v in pairs(game:GetDescendants()) do
            if v:IsA("BasePart") then v.Material = Enum.Material.SmoothPlastic end
            if v:IsA("Decal") then v:Destroy() end
        end
        WindUI:Notify("Performance", "Map Optimized!", 2)
    end
})

